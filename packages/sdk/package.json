{
  "name": "@neuroos/sdk",
  "version": "0.1.0",
  "description": "NeuroOS Developer SDK — TypeScript/JavaScript client for the NeuroOS Platform API",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@neuroos/platform-core": "workspace:*",
    "@neuroos/shared-contracts": "workspace:*",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.0",
    "@types/ws": "^8.5.10",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  }
}
