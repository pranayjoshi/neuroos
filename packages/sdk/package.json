{
  "name": "@neuroos/sdk",
  "version": "0.1.0",
  "description": "NeuroOS Developer SDK — TypeScript/JavaScript client for the NeuroOS Platform API",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@neuroos/shared-contracts": "workspace:*",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "vitest": "^1.4.0"
  }
}
