{
  "name": "@neuroos/platform-core",
  "version": "0.1.0",
  "description": "NeuroOS Platform Core — OS layer (DeviceRegistry, SessionManager, PipelineOrchestrator, REST/WS API)",
  "private": true,
  "type": "module",
  "main": "./dist/api/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "node --watch dist/api/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/websocket": "^8.3.0",
    "@fastify/cors": "^9.0.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@neuroos/shared-contracts": "workspace:*",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.8",
    "vitest": "^1.4.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "ws": "^8.16.0",
    "@types/ws": "^8.5.10"
  }
}
