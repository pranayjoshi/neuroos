{
  "name": "@neuroos/shared-contracts",
  "version": "0.1.0",
  "description": "Typed data contracts shared across all NeuroOS modules",
  "private": true,
  "type": "module",
  "exports": {
    "./schema": {
      "types": "./schema/index.ts",
      "import": "./schema/index.ts"
    },
    "./constants": {
      "types": "./constants/index.ts",
      "import": "./constants/index.ts"
    },
    "./json-schema/*": "./json-schema/*.schema.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate-schemas": "node --experimental-vm-modules scripts/validate-schemas.mjs",
    "clean": "echo 'nothing to clean (no build output)'"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.4.5"
  }
}
